---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";

const articles = (await getCollection("blog")).sort((a, b) => b.data.date.localeCompare(a.data.date));
const categories = ["全部", ...Array.from(new Set(articles.map((article) => article.data.category)))];
---

<BaseLayout title="文章 | keinYe" currentPath="/blog/">
  <section class="section article-index-section">
    <div class="container">
      <div class="category-bar" aria-label="文章分类">
        {categories.map((category, index) => (
          <button
            type="button"
            class={index === 0 ? "active" : ""}
            aria-pressed={index === 0 ? "true" : "false"}
            data-category={category}
          >
            {category}
          </button>
        ))}
      </div>

      <div class="post-list" aria-label="文章列表">
        {articles.map((article) => (
          <a
            class="post-row"
            href={`/blog/${article.id.replace(/\.md$/, "")}/`}
            data-category={article.data.category}
          >
            <div class="post-time">
              <time datetime={article.data.date}>{article.data.date}</time>
              <span>{article.data.readTime}</span>
            </div>
            <div class="post-main">
              <h2>{article.data.title}</h2>
              <p>{article.data.summary}</p>
            </div>
            <span class="post-tag">{article.data.category}</span>
          </a>
        ))}
      </div>

      <nav class="pagination" aria-label="分页">
        <span aria-current="page">1</span>
      </nav>
    </div>
  </section>

  <script>
    const buttons = document.querySelectorAll<HTMLButtonElement>(".category-bar button");
    const rows = document.querySelectorAll<HTMLAnchorElement>(".post-list .post-row");

    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        const target = button.dataset.category ?? "全部";

        buttons.forEach((b) => {
          const isActive = b === button;
          b.classList.toggle("active", isActive);
          b.setAttribute("aria-pressed", isActive ? "true" : "false");
        });

        rows.forEach((row) => {
          const match = target === "全部" || row.dataset.category === target;
          row.hidden = !match;
        });
      });
    });
  </script>
</BaseLayout>
